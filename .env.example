# =====================================================================
# Meeting Assistant - Environment Configuration
# Copy this file to `.env` and fill in your values.
# =====================================================================

# ---------------------------------------------------------------------
# OpenRouter (Free LLM models for summarization & analysis)
# Sign up at https://openrouter.ai (no credit card required for free tier).
# Create an API key under your profile -> Keys.
# ---------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free models examples (the OpenRouter free catalog rotates; check
# https://openrouter.ai/models?q=free for the current list):
#   openrouter/free                           (auto-pick a currently-free model)
#   deepseek/deepseek-chat-v3-0324:free       (good general chat)
#   meta-llama/llama-3.3-70b-instruct:free    (robust, follows JSON instructions well)
#   google/gemma-3-27b-it:free                (fast & lightweight)
#   deepseek/deepseek-r1:free                 (slower, stronger reasoning)
LLM_MODEL=openrouter/free

# ---------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=iwasist

# ---------------------------------------------------------------------
# Temporal
# ---------------------------------------------------------------------
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=meeting-processing-queue

# ---------------------------------------------------------------------
# Local Whisper (Speech-to-Text)
# Models (ordered by accuracy / size / speed): tiny, base, small, medium, large-v3
# `base` is a good free default (~140 MB).
# ---------------------------------------------------------------------
WHISPER_SERVICE_URL=http://whisper:9000
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ---------------------------------------------------------------------
# Authentication
# Default = simple admin/admin. Replace later with OAuth/SSO by
# implementing a new AuthProvider in backend/app/auth/.
# ---------------------------------------------------------------------
AUTH_PROVIDER=simple
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_SECRET_KEY=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Future OAuth (uncomment & fill when ready)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------
# Real tool integrations (disabled until implemented)
# See docs/tool-integrations.md for the Gmail adapter path.
# ---------------------------------------------------------------------
GMAIL_ENABLED=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/integrations/google/oauth/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.compose
GMAIL_TOKEN_ENCRYPTION_KEY=

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
APP_ENV=development
FRONTEND_URL=http://localhost:3000
UPLOADS_DIR=/uploads
MAX_AUDIO_UPLOAD_MB=200
